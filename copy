from pathlib import Path
import re

# Path to the text template, hardcoded in the script
TEMPLATE_FILE = Path("template.txt")

TOPIC_TOKEN = "{{TOPIC}}"
FLOW_TOKEN = "{{FLOW}}"


def ask_topic_name() -> str:
    while True:
        topic_name = input("Topic name (no spaces): ").strip()

        if not topic_name:
            print("Error: the topic name cannot be empty.")
            continue

        if any(character.isspace() for character in topic_name):
            print("Error: the topic name must not contain spaces.")
            continue

        return topic_name


def ask_flow_name() -> str:
    while True:
        flow_name = input("Flow name: ").strip()

        if not flow_name:
            print("Error: the flow name cannot be empty.")
            continue

        # Replace spaces and underscores with hyphens
        flow_name = re.sub(r"[\s_]+", "-", flow_name)

        # Remove hyphens at the beginning and end
        flow_name = flow_name.strip("-")

        if not flow_name:
            print("Error: the flow name must contain valid characters.")
            continue

        return flow_name


def main() -> None:
    topic_name = ask_topic_name()
    flow_name = ask_flow_name()

    try:
        template = TEMPLATE_FILE.read_text(encoding="utf-8")
    except FileNotFoundError:
        print(f"Error: file '{TEMPLATE_FILE}' was not found.")
        return
    except OSError as error:
        print(f"Error while reading the file: {error}")
        return

    final_text = (
        template
        .replace(TOPIC_TOKEN, topic_name)
        .replace(FLOW_TOKEN, flow_name)
    )

    print("\n--- Generated text ---\n")
    print(final_text)


if __name__ == "__main__":
    main()
